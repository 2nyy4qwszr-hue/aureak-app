# Aureak — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Valeurs locales : disponibles après `supabase start` (affichées dans le terminal)

# Supabase — URL et clé anonyme
# Local dev : http://127.0.0.1:54321 (après `supabase start`)
# Remote    : disponible dans le dashboard Supabase > Settings > API
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7urOL8_Hb0qOQR6qQECgIZHEVpJCo_B2Pbo

# Supabase Service Role — JAMAIS exposé côté client / apps
# Réservé : Edge Functions, CI/CD, scripts de migration
# Ne jamais commiter cette valeur réelle — utiliser les secrets CI
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Project Ref — pour `supabase link`
SUPABASE_PROJECT_REF=
